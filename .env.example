SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Session persistence cookie encryption key.
# Google-only auth still uses this to keep users logged in across app restarts.
# セッション永続化Cookieの暗号鍵。Google認証でも利用されます。
TRUSTED_DEVICE_SECRET=replace-with-a-long-random-string

# Session persistence duration in days (1-365).
# セッション継続日数（1-365）。
TRUSTED_DEVICE_DAYS=30

# OAuth post-login return URL override.
# If empty, local mode falls back to http://127.0.0.1:8501.
# OAuthログイン後の戻り先URL。未設定時はローカル判定で http://127.0.0.1:8501 を使用。
OAUTH_REDIRECT_TO=http://127.0.0.1:8501

# Optional: local Supabase CLI Google OAuth provider settings.
# These are read by supabase/config.toml via env(...).
# 任意: ローカルSupabase CLIのGoogle OAuth有効化に必要。
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
